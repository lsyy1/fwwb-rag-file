# -----------------------------------------------------------------------------
# RAGFlow FWWB 比赛专用配置文件
# 评委部署时请复制此文件为 .env 并根据需要修改
# -----------------------------------------------------------------------------

# ------------------------------
# 核心配置
# ------------------------------
# 文档引擎类型: elasticsearch / infinity / oceanbase / opensearch / seekdb
DOC_ENGINE=elasticsearch

# 运行设备: cpu / gpu
DEVICE=cpu

# 比赛专用镜像（固定版本）
RAGFLOW_IMAGE=lsyy1/ragflow-fwwb:1.0.0

# ------------------------------
# 端口配置（与文档保持一致）
# ------------------------------
# 前端端口
SVR_WEB_HTTP_PORT=9222
SVR_WEB_HTTPS_PORT=443

# 后端API端口
SVR_HTTP_PORT=9380
ADMIN_SVR_HTTP_PORT=9381

# 数据库端口（内部使用）
MYSQL_PORT=3306
ES_PORT=1200
REDIS_PORT=6379
MINIO_PORT=9000

# ------------------------------
# 内存配置（建议至少 16GB 内存）
# ------------------------------
MEM_LIMIT=16147483648

# ------------------------------
# 密码配置（演示环境使用默认密码）
# ------------------------------
MYSQL_PASSWORD=infini_rag_flow
ELASTIC_PASSWORD=infini_rag_flow
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow
REDIS_PASSWORD=infini_rag_flow

# ------------------------------
# 时区配置
# ------------------------------
TZ=Asia/Shanghai

# ------------------------------
# 其他配置
# ------------------------------
REGISTER_ENABLED=1
API_PROXY_SCHEME=python